# ====================================
# Cinematic MCP — 环境变量配置模板
# ====================================
# 使用方法：cp .env.example .env，然后按需修改

# ComfyUI 地址（Docker 容器间通信用服务名，不要用 localhost）
COMFYUI_BASE_URL=http://comfyui:8188
COMFYUI_EXECUTOR_TYPE=http

# Pixelle 服务配置
HOST=0.0.0.0
PORT=9004

# 禁用 Chainlit 认证（纯 MCP 工具模式）
CHAINLIT_AUTH_ENABLED=false
CHAINLIT_SAVE_STARTER_ENABLED=false

# CDN 策略（国内用 china，海外用 global，自动检测用 auto）
CDN_STRATEGY=china

# LLM Provider 配置
# 纯 MCP 工具模式不需要 LLM，但 Pixelle 启动检查要求至少配置一个
# Ollama 未运行也不影响 MCP 工具功能
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODELS=qwen2.5:7b

# 若需使用其他 LLM provider（可选，仅影响 Chainlit Web 对话功能，不影响 MCP 工具）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# CHAINLIT_CHAT_OPENAI_MODELS=gpt-4o-mini
