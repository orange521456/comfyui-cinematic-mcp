# ====================================
# Cinematic MCP — .gitignore
# ====================================

# --- 敏感配置 ---
.env
.env.local
.env.*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- 本地 pip target 目录（torch 等大库） ---
pylibs/
*.whl

# --- 日志 ---
*.log
logs/

# --- 生成图片 / 临时输出 ---
comfyui_output/*.png
comfyui_output/*.jpg
comfyui_output/*.jpeg
comfyui_output/*.webp
comfyui_input/*
!comfyui_output/.gitkeep
!comfyui_input/.gitkeep

# --- Pixelle 运行时文件 ---
data/files/*
!data/files/.gitkeep

# --- IDE / 编辑器 ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Docker ---
# Pixelle-MCP 是 fork 的子项目，需用户自行 clone（见 README 步骤 1）
# 不纳入本仓库，避免双重维护
Pixelle-MCP/

